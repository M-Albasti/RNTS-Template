<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/prayer_widget_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/prayer_widget_background"
  android:orientation="vertical"
  android:padding="12dp">

  <TextView
    android:id="@+id/prayer_widget_location"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="Location"
    android:textColor="#D4AF37"
    android:textSize="14sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/prayer_widget_timezone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="Timezone"
    android:textColor="#A8C5B5"
    android:textSize="11sp" />

  <TextView
    android:id="@+id/prayer_widget_next"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="Next prayer"
    android:textColor="#FFFFFF"
    android:textSize="16sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/prayer_widget_countdown"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:text="--"
    android:textColor="#D4AF37"
    android:textSize="13sp" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/prayer_widget_fajr"
        android:textColor="#A8C5B5"
        android:textSize="10sp" />

      <TextView
        android:id="@+id/prayer_widget_fajr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/prayer_widget_dhuhr"
        android:textColor="#A8C5B5"
        android:textSize="10sp" />

      <TextView
        android:id="@+id/prayer_widget_dhuhr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/prayer_widget_asr"
        android:textColor="#A8C5B5"
        android:textSize="10sp" />

      <TextView
        android:id="@+id/prayer_widget_asr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/prayer_widget_maghrib"
        android:textColor="#A8C5B5"
        android:textSize="10sp" />

      <TextView
        android:id="@+id/prayer_widget_maghrib"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/prayer_widget_isha"
        android:textColor="#A8C5B5"
        android:textSize="10sp" />

      <TextView
        android:id="@+id/prayer_widget_isha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:orientation="horizontal">

    <Button
      android:id="@+id/prayer_widget_remind"
      android:layout_width="0dp"
      android:layout_height="36dp"
      android:layout_marginEnd="8dp"
      android:layout_weight="1"
      android:background="@drawable/prayer_widget_button"
      android:contentDescription="@string/prayer_widget_remind"
      android:text="@string/prayer_widget_remind"
      android:textAllCaps="false"
      android:textColor="#0F3D2E"
      android:textSize="12sp"
      android:textStyle="bold" />

    <Button
      android:id="@+id/prayer_widget_open"
      android:layout_width="0dp"
      android:layout_height="36dp"
      android:layout_weight="1"
      android:background="@drawable/prayer_widget_button_outline"
      android:contentDescription="@string/prayer_widget_open"
      android:text="@string/prayer_widget_open"
      android:textAllCaps="false"
      android:textColor="#D4AF37"
      android:textSize="12sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
