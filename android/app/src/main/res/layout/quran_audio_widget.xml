<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/quran_widget_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/quran_widget_background"
  android:orientation="vertical"
  android:padding="12dp">

  <TextView
    android:id="@+id/quran_widget_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:contentDescription="@string/quran_widget_open"
    android:text="Quran"
    android:textColor="#FFFFFF"
    android:textSize="16sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/quran_widget_subtitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:text="Ayah 1"
    android:textColor="#E0F2F1"
    android:textSize="13sp" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:gravity="center"
    android:orientation="horizontal">

    <ImageButton
      android:id="@+id/quran_widget_prev"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:layout_marginEnd="4dp"
      android:background="@drawable/quran_widget_control_bg"
      android:contentDescription="@string/quran_widget_prev"
      android:padding="8dp"
      android:scaleType="fitCenter"
      android:src="@drawable/ic_widget_prev" />

    <ImageButton
      android:id="@+id/quran_widget_play"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:layout_marginEnd="4dp"
      android:background="@drawable/quran_widget_control_bg"
      android:contentDescription="@string/quran_widget_play"
      android:padding="10dp"
      android:scaleType="fitCenter"
      android:src="@drawable/ic_widget_play" />

    <ImageButton
      android:id="@+id/quran_widget_next"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:layout_marginEnd="4dp"
      android:background="@drawable/quran_widget_control_bg"
      android:contentDescription="@string/quran_widget_next"
      android:padding="8dp"
      android:scaleType="fitCenter"
      android:src="@drawable/ic_widget_next" />

    <ImageButton
      android:id="@+id/quran_widget_repeat"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:layout_marginEnd="4dp"
      android:background="@drawable/quran_widget_control_bg"
      android:contentDescription="@string/quran_widget_repeat"
      android:padding="8dp"
      android:scaleType="fitCenter"
      android:src="@drawable/ic_widget_repeat" />

    <ImageButton
      android:id="@+id/quran_widget_stop"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:background="@drawable/quran_widget_control_bg"
      android:contentDescription="@string/quran_widget_stop"
      android:padding="8dp"
      android:scaleType="fitCenter"
      android:src="@drawable/ic_widget_stop" />
  </LinearLayout>
</LinearLayout>
