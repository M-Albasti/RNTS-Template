<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/quran_widget_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/quran_widget_background"
  android:orientation="vertical"
  android:padding="12dp">

  <TextView
    android:id="@+id/quran_widget_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Quran"
    android:textColor="#FFFFFF"
    android:textSize="16sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/quran_widget_subtitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:text="Ayah 1 · Surah 1"
    android:textColor="#E0F2F1"
    android:textSize="13sp" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:gravity="center"
    android:orientation="horizontal">

    <Button
      android:id="@+id/quran_widget_prev"
      android:layout_width="0dp"
      android:layout_height="36dp"
      android:layout_marginEnd="6dp"
      android:layout_weight="1"
      android:background="@drawable/quran_widget_button"
      android:text="@string/quran_widget_prev"
      android:textAllCaps="false"
      android:textColor="#004D40"
      android:textSize="12sp" />

    <Button
      android:id="@+id/quran_widget_play"
      android:layout_width="0dp"
      android:layout_height="36dp"
      android:layout_marginEnd="6dp"
      android:layout_weight="1"
      android:background="@drawable/quran_widget_button"
      android:text="@string/quran_widget_play"
      android:textAllCaps="false"
      android:textColor="#004D40"
      android:textSize="12sp" />

    <Button
      android:id="@+id/quran_widget_next"
      android:layout_width="0dp"
      android:layout_height="36dp"
      android:layout_weight="1"
      android:background="@drawable/quran_widget_button"
      android:text="@string/quran_widget_next"
      android:textAllCaps="false"
      android:textColor="#004D40"
      android:textSize="12sp" />
  </LinearLayout>
</LinearLayout>
