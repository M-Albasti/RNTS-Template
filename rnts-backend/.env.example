NODE_ENV=development
PORT=3000
API_PREFIX=v1

# Database (SQLite for local dev; set DATABASE_URL for PostgreSQL)
DATABASE_PATH=./data/rnts.sqlite

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# OTP (development: log codes to console)
OTP_EXPIRES_MINUTES=10

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*
